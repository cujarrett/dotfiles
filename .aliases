alias "cleanraws"="clean-up-raws.sh"

alias "vssettings"="open -a 'Visual Studio Code' \"$HOME/Library/Application Support/Code/User/settings.json\""

alias k="kubectl"

alias "python"="python3"
alias "pip"="pip3"

alias "tf"="terraform"

alias "kioskreboot"='ssh pi@192.168.10.100 "sudo systemctl restart getty@tty1.service"'

alias "homelabcert"='k get secret local-lab-ca-secret -n cert-manager -o jsonpath="{.data.tls\.crt}" | base64 -d > ~/Desktop/local-lab-ca.crt && echo "Certificate saved to ~/Desktop/local-lab-ca.crt. On iOS and ipadOS: Settings > General > VPN & Device Management to install, then Settings > VPN to enable"'

kcheck() {
  echo "=== Cluster Nodes ==="
  k get nodes -o wide --no-headers | awk '{print $1, $2, $5}'

  echo ""
  echo "=== Argo Apps ==="
  k get applications -n argocd --no-headers | awk '{print $1, $2, $3}'

  echo ""
  echo "=== Unhealthy Pods ==="
  k get pods -A --no-headers | grep -v "Running\|Completed" | awk '{print $1, $2, $4}'

  echo ""
  echo "=== Crossplane XRs ==="
  k get composite --no-headers 2>/dev/null | awk '{print $1, $2}'

  echo ""
  echo "=== Unhealthy Crossplane XRs ==="
  k get composite --no-headers 2>/dev/null | awk '$2!="True" {print $1, $2}'

  echo ""
  echo "=== Unbound PVCs ==="
  k get pvc -A --no-headers | grep -v Bound | awk '{print $1, $2, $3}'

  echo ""
  echo "=== Orphaned Longhorn Volumes ==="
  k get volumes -n longhorn-system --no-headers 2>/dev/null | awk '$3=="detached" && $7=="" {print $1, $3}'
}